# Frontend AGAGI — variables Vite (exposées au build, préfixe VITE_ obligatoire).
# Copier en frontend/.env.local (non versionné).

# Base URL de l'API backend. Absent -> http://localhost:8001
VITE_API_BASE_URL=

# Token API : doit correspondre à AGAGI_API_TOKEN côté backend SI celui-ci est activé.
# Absent -> aucun header Authorization envoyé (défaut).
VITE_API_TOKEN=
