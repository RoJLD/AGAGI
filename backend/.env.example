# Sécurité backend AGAGI (F3.12) — toutes opt-in, NON-breaking par défaut.
# Copier en backend/.env (non versionné) et adapter pour exposer le dashboard hors localhost.

# Origines CORS autorisées (CSV). Absent/vide -> "*" (tout autorisé, défaut historique).
# Exemple production : AGAGI_CORS_ORIGINS=https://dashboard.mondomaine.fr,https://autre.fr
AGAGI_CORS_ORIGINS=

# Token d'API. Absent/vide -> aucune auth (défaut). Si défini, exige
# `Authorization: Bearer <token>` sur les MUTATIONS /api (POST/PUT/PATCH/DELETE).
# Les lectures (GET) restent toujours libres.
# Générer : python -c "import secrets; print(secrets.token_urlsafe(32))"
AGAGI_API_TOKEN=
